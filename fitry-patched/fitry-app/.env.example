# ─────────────────────────────────────────────────────────────────────
#  Fitry App — Environment Variables
#  Copy this to .env and fill in your values. NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────────────

# Firebase config — from Firebase Console → Project Settings → Your Apps
VITE_FIREBASE_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxxxxxxxxxx

# Gemini API key — free from https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
